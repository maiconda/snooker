# ==============================================================================
# Configurações do Google OAuth
# ==============================================================================
# Client ID do aplicativo cadastrado no Google Cloud Console
GOOGLE_CLIENT_ID=seu_client_id_aqui.apps.googleusercontent.com

# ==============================================================================
# Segurança e JWT
# ==============================================================================
# Chave secreta longa e forte para assinatura do JWT (ex: openssl rand -hex 32)
JWT_SECRET=sua_chave_secreta_longa_e_segura_aqui

# ==============================================================================
# Conexão com o Banco de Dados (PostgreSQL)
# ==============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=snooker_db
DB_SSLMODE=disable

# ==============================================================================
# Conexão com o Object Storage (MinIO / S3)
# ==============================================================================
STORAGE_ENDPOINT=localhost:9005
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_USE_SSL=false
STORAGE_BUCKET_NAME=snooker-profiles
# URL pública para o frontend fazer upload e acessar as fotos de perfil.
# Em produção, altere para o seu domínio (ex: https://snooker.maiconda.com/snooker-profiles)
STORAGE_PUBLIC_BASE_URL=http://localhost:3000/snooker-profiles

# Opcionais do Object Storage
STORAGE_REGION=us-east-1
PROFILE_MAX_PHOTO_BYTES=2097152

# ==============================================================================
# Configurações do Servidor
# ==============================================================================
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000
AUTH_ALLOWED_ORIGINS=http://localhost:3000
PROFILE_ALLOWED_ORIGINS=http://localhost:3000
GAME_ALLOWED_ORIGINS=http://localhost:3000
MINIO_API_CORS_ALLOW_ORIGIN=*
INTERNAL_API_KEY=sua_chave_interna_longa_e_segura_aqui
GAME_OWNER_DISCONNECT_TIMEOUT_SECONDS=10
PROFILE_INTERNAL_URL=http://localhost:8082

# Opcionais/Auxiliares de Inicialização do MinIO (Docker)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9005
MINIO_CONSOLE_PORT=9001
PROFILE_LEGACY_DB_NAME=snooker_profile

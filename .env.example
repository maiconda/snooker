# ==============================================================================
# Configurações do Google OAuth
# ==============================================================================
# Client ID do aplicativo cadastrado no Google Cloud Console
GOOGLE_CLIENT_ID=seu_client_id_aqui.apps.googleusercontent.com

# ==============================================================================
# Segurança e JWT
# ==============================================================================
# Chave secreta longa e forte para assinatura do JWT (ex: openssl rand -hex 32)
JWT_SECRET=sua_chave_secreta_longa_e_segura_aqui

# Chave compartilhada somente entre servicos internos
INTERNAL_API_KEY=sua_chave_interna_longa_e_segura_aqui

# ==============================================================================
# Conexão com o Banco de Dados (PostgreSQL)
# ==============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=snooker_db
DB_SSLMODE=disable

# ==============================================================================
# Conexão com o Object Storage (MinIO / S3)
# ==============================================================================
STORAGE_ENDPOINT=localhost:9000
STORAGE_PUBLIC_BASE_URL=http://localhost:9005/snooker-profiles
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_USE_SSL=false
STORAGE_BUCKET_NAME=snooker-profiles
STORAGE_REGION=us-east-1
PROFILE_MAX_PHOTO_BYTES=2097152

# ==============================================================================
# MinIO local/producao
# ==============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_CORS_ALLOW_ORIGIN=http://localhost:3000
MINIO_API_PORT=9005
MINIO_CONSOLE_PORT=9001

# ==============================================================================
# Configurações do Servidor
# ==============================================================================
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000
